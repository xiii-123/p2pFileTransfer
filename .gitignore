# Binary files
bin/
*.exe
*.dll
*.so
*.dylib
p2p-server*

doc/

# Test outputs
test_results/
test_*_results.txt
*.log

# Build artifacts (except build.bat which is needed)
!build.bat
*.sh

# Test scripts (all test-related scripts)
run_multinode_tests.*
*_test.ps1
*_test.sh
*_test.bat
test*.bat
test*.sh

# Temporary files
*.tmp
*.swp
*.bak
*~
nul

# Test directories (all test files are for local development only)
test/
tests/
test_*/
quick_test/

# Metadata and private keys (sensitive data)
metadata/*.json
metadata/*.key
chameleon_key.json
generate_keys.go

# Test reports
TEST_REPORT.md
TEST_SUMMARY.txt

# Test configuration with private keys (security)
test/config/test.env
test/config/test_config.json
test/config/test_private_key.json
test/config/*.key
test/config/*_private_key.json

# IDE files
.claude
.idea
.vscode/
*.code-workspace

# OS files
.DS_Store
Thumbs.db

# Claude Code settings
.claude/settings.local.json